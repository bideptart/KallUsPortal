# NIXXY — environment template.
# Copy to `.env` and fill in real values. The real `.env` is gitignored and is
# NEVER committed. Do not put credentials in this file.

# --- Postgres ---------------------------------------------------------------
PG_HOST=
PG_PORT=
PG_DB=
PG_USER=
PG_PASSWORD=

# --- App --------------------------------------------------------------------
# Backend API port. NIXXY runs its own backend, separate from any other stack.
PORT=4100
SESSION_SECRET=
# Public URL the app/Twilio callbacks resolve to (frontend host:port).
PUBLIC_BASE_URL=

# --- Twilio -----------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_AUTH_TOKEN=
TWILIO_DEFAULT_NUMBER=
# Twilio SIP IPs (for LiveKit trunk allowlist)
SIP_GATEWAY_IP=

# --- MCP / Dashboard --------------------------------------------------------
MCP_URL=
MCP_TOKEN=
DASHBOARD_BASE_URL=
DASHBOARD_EMAIL=
DASHBOARD_PASSWORD=

# Reseller scoping — which reseller portal this deployment represents.
RESELLER_PORTAL=

# --- Numbers ----------------------------------------------------------------
NUMBER_PRICE_MARKUP=
NUMBER_PROVIDER=
MANUAL_NUMBERS=

# --- AI keys ----------------------------------------------------------------
XAI_API_KEY=
OPENAI_API_KEY=
TTS_PREVIEW_TEXT=
GOOGLE_API_KEY=
GOOGLE_TTS_API_KEY=

# --- Stripe -----------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=
